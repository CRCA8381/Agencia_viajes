@page "/"
<PageTitle>Inicio</PageTitle>
<section class="hero">
  <div>
    <span class="eyebrow">Sistema de gestión turística</span>
    <h1>Administra una agencia de viajes con .NET</h1>
    <p>Controla destinos, paquetes turísticos, clientes y reservas desde una sola aplicación web.</p>
    <div class="actions">
      <a class="btn primary" href="/reservas">Gestionar reservas</a>
      <a class="btn secondary" href="/paquetes">Ver paquetes</a>
    </div>
  </div>
  <div>
    <h2>Arquitectura</h2>
    <ul>
      <li>Frontend: Blazor WebAssembly</li>
      <li>Backend: ASP.NET Core Web API</li>
      <li>ORM: Entity Framework Core</li>
      <li>Base de datos: PostgreSQL</li>
    </ul>
  </div>
</section>
